---
import { useTranslations, type Locale } from '../i18n/utils';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer>
  <p>
    {t('footer.credit')}
    <a href="/" class="text-sakura no-underline italic">zoecodes</a> · {year}
  </p>
</footer>

<style>
  footer {
    background: var(--color-text-primary);
    color: color-mix(in srgb, var(--color-white) 40%, transparent 100%);
    padding: 1.5rem;
    text-align: center;
    font-size: 0.75rem;
  }
</style>
