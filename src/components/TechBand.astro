---
import gitSvg from '../assets/icons/git.svg?raw';
import ghSvg from '../assets/icons/gh.svg?raw';
import jsSvg from '../assets/icons/js.svg?raw';
import tsSvg from '../assets/icons/ts.svg?raw';
import rctSvg from '../assets/icons/rct.svg?raw';
import expoSvg from '../assets/icons/expo.svg?raw';
import nodeSvg from '../assets/icons/node.svg?raw';
import exprSvg from '../assets/icons/expr.svg?raw';
import sqlSvg from '../assets/icons/sql.svg?raw';
import htmlSvg from '../assets/icons/html.svg?raw';
import cssSvg from '../assets/icons/css.svg?raw';
import twSvg from '../assets/icons/tw.svg?raw';
import fmSvg from '../assets/icons/fm.svg?raw';
import awSvg from '../assets/icons/aw.svg?raw';
import astroSvg from '../assets/icons/astro.svg?raw';
import vitSvg from '../assets/icons/vite.svg?raw';
import vtSvg from '../assets/icons/vt.svg?raw';
import nlfySvg from '../assets/icons/nlfy.svg?raw';
import figSvg from '../assets/icons/fig.svg?raw';
import vueSvg from '../assets/icons/vue.svg?raw';

interface Tech {
  name: string;
  abbr: string;
  icon: string;
}

const techs: Tech[] = [
  { name: 'Git', abbr: 'GIT', icon: gitSvg },
  { name: 'GitHub', abbr: 'GH', icon: ghSvg },
  { name: 'JavaScript', abbr: 'JS', icon: jsSvg },
  { name: 'TypeScript', abbr: 'TS', icon: tsSvg },
  { name: 'React', abbr: 'RCT', icon: rctSvg },
  { name: 'Expo', abbr: 'EXP', icon: expoSvg },
  { name: 'Node.js', abbr: 'NODE', icon: nodeSvg },
  { name: 'Express', abbr: 'EXPR', icon: exprSvg },
  { name: 'MySQL', abbr: 'SQL', icon: sqlSvg },
  { name: 'HTML', abbr: 'HTML', icon: htmlSvg },
  { name: 'CSS', abbr: 'CSS', icon: cssSvg },
  { name: 'Tailwind', abbr: 'TW', icon: twSvg },
  { name: 'FramerMotion', abbr: 'FM', icon: fmSvg },
  { name: 'Appwrite', abbr: 'AW', icon: awSvg },
  { name: 'Astro', abbr: 'ASTRO', icon: astroSvg },
  { name: 'Vite', abbr: 'VIT', icon: vitSvg },
  { name: 'Vitest', abbr: 'VT', icon: vtSvg },
  { name: 'Netlify', abbr: 'Nlfy', icon: nlfySvg },
  { name: 'Figma', abbr: 'FIG', icon: figSvg },
  { name: 'Vue', abbr: 'VUE', icon: vueSvg },
];
---

<section class="tech-band">
  <h2 class="section-label">Tech Stack</h2>

  <ul class="tech-band__grid palette-cycle" role="list" aria-label="Tech stack">
    {
      techs.map((tech) => (
        <li class="tech-item">
          <figure class="tech-item__figure">
            <svg
              class="tech-item__star"
              viewBox="0 0 100 100"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M50,2 Q47,47 2,50 Q47,53 50,98 Q53,53 98,50 Q53,47 50,2Z" />
            </svg>
            <span class="tech-icon" aria-hidden="true" set:html={tech.icon} />
            <figcaption class="tech-item__name">{tech.name}</figcaption>
          </figure>
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* ── Section ─────────────────────────────────────────────────── */

  .tech-band {
    background-color: var(--color-surface);
  }

  /* overrides .section-label margin-bottom for extra breathing room */
  .tech-band h2 {
    margin-bottom: 2.5rem;
  }

  /* ── Grid ────────────────────────────────────────────────────── */

  .tech-band__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem 2.5rem;
    list-style: none;
    max-width: 60rem;
    margin-inline: auto;
    padding-inline: 2rem;
  }

  /* ── Figure: star and abbr overlap in the same grid cell ─────── */

  .tech-item__figure {
    display: grid;
    grid-template-columns: 1fr;
    justify-items: center;
    row-gap: 0.5rem;
    margin: 0;
  }

  .tech-item__star {
    grid-row: 1;
    grid-column: 1;
    width: 5.5rem;
    height: 5.5rem;
  }

  .tech-item__star path {
    fill: color-mix(in srgb, var(--color) 40%, white);
    stroke: var(--color);
    stroke-width: 1.5;
  }

  .tech-icon {
    grid-row: 1;
    grid-column: 1;
    align-self: center;
    display: flex;
    align-items: center;
    justify-content: center;
    color: color-mix(in hsl, var(--color) 60%, black 50%);
    z-index: 1;
  }

  .tech-icon :global(svg) {
    fill: currentColor;
    width: 1.75rem;
    height: 1.75rem;
  }

  /* ── Tech name ───────────────────────────────────────────────── */

  .tech-item__name {
    grid-row: 2;
    grid-column: 1;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: center;
  }

  /* ── Mobile ──────────────────────────────────────────────────── */

  @media (max-width: 480px) {
    .tech-band__grid {
      gap: 1.5rem 1.75rem;
    }

    .tech-item__star {
      width: 4.5rem;
      height: 4.5rem;
    }
  }
</style>

<script>
  import { scroll } from 'motion';

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  if (!prefersReducedMotion) {
    const section = document.querySelector<HTMLElement>('.tech-band')!;
    const items = [...document.querySelectorAll<HTMLElement>('.tech-item')];
    const n = items.length;

    items.forEach((item) => {
      item.style.opacity = '0';
      item.style.transform = 'translateY(12px)';
    });

    scroll(
      (p: number) => {
        items.forEach((item, i) => {
          // Spread items across the first 60% of the scroll range so all are
          // fully visible by the time the section is completely in the viewport.
          // Each item fades over a 7% window of scroll progress.
          const sliceStart = (i / n) * 0.8;
          const sliceEnd = 0.07;
          const t = Math.max(0, Math.min(1, (p - sliceStart) / sliceEnd));
          item.style.opacity = String(t);
          item.style.transform = `translateY(${(t - 1) * -50}px)`;
        });
      },
      {
        target: section,
        offset: ['start end', 'end start'],
      },
    );
  }
</script>
