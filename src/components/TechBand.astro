---
interface Tech {
  name: string;
  abbr: string;
}

const techs: Tech[] = [
  { name: 'JavaScript', abbr: 'JS' },
  { name: 'TypeScript', abbr: 'TS' },
  { name: 'React', abbr: 'RCT' },
  { name: 'Expo', abbr: 'EXP' },
  { name: 'Vue', abbr: 'VUE' },
  { name: 'Node.js', abbr: 'NODE' },
  { name: 'Express', abbr: 'EXPR' },
  { name: 'MySQL', abbr: 'SQL' },
  { name: 'CSS', abbr: 'CSS' },
  { name: 'Git', abbr: 'GIT' },
  { name: 'Figma', abbr: 'FIG' },
];
---

<section class="tech-band">
  <h2
    class="text-xs tracking-widest uppercase font-semibold text-muted text-center"
  >
    Tech Stack
  </h2>

  <ul class="tech-band__grid" role="list" aria-label="Tech stack">
    {
      techs.map((tech) => (
        <li class="tech-item">
          <figure class="tech-item__figure">
            <svg
              class="tech-item__star"
              viewBox="0 0 100 100"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
              focusable="false"
            >
              <path d="M50,2 Q47,47 2,50 Q47,53 50,98 Q53,53 98,50 Q53,47 50,2Z" />
            </svg>
            <span class="tech-item__abbr" aria-hidden="true">
              {tech.abbr}
            </span>
            <figcaption class="tech-item__name">{tech.name}</figcaption>
          </figure>
        </li>
      ))
    }
  </ul>
</section>

<style>
  /* ── Section ─────────────────────────────────────────────────── */

  .tech-band {
    background-color: var(--color-surface);
  }

  /* h2 spacing — visual appearance handled via Tailwind in markup */
  .tech-band h2 {
    margin-bottom: 2.5rem;
  }

  /* ── Grid ────────────────────────────────────────────────────── */

  .tech-band__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 2rem 2.5rem;
    list-style: none;
    max-width: 60rem;
    margin-inline: auto;
    padding-inline: 2rem;
  }

  /* ── Item color tokens ───────────────────────────────────────── */

  .tech-item {
    --item-surface: var(--ice-surface);
    --item-color: var(--color-ice);
    --item-on: var(--on-ice);
  }

  .tech-item:nth-child(5n) {
    --item-surface: var(--lavender-surface);
    --item-color: var(--color-lavender);
    --item-on: var(--on-lavender);
  }

  .tech-item:nth-child(5n + 1) {
    --item-surface: var(--sakura-surface);
    --item-color: var(--color-sakura);
    --item-on: var(--on-sakura);
  }

  .tech-item:nth-child(5n + 2) {
    --item-surface: var(--periwinkle-surface);
    --item-color: var(--color-periwinkle);
    --item-on: var(--on-periwinkle);
  }

  .tech-item:nth-child(5n + 3) {
    --item-surface: var(--blush-surface);
    --item-color: var(--color-blush);
    --item-on: var(--on-blush);
  }

  /* ── Figure: star and abbr overlap in the same grid cell ─────── */

  .tech-item__figure {
    display: grid;
    grid-template-columns: 1fr;
    justify-items: center;
    row-gap: 0.5rem;
    margin: 0;
  }

  .tech-item__star {
    grid-row: 1;
    grid-column: 1;
    width: 5.5rem;
    height: 5.5rem;
  }

  .tech-item__star path {
    fill: var(--item-surface);
    stroke: var(--item-color);
    stroke-width: 1.5;
  }

  .tech-item__abbr {
    grid-row: 1;
    grid-column: 1;
    align-self: center;
    font-size: 0.6875rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    color: var(--item-on);
    z-index: 1;
    user-select: none;
  }

  /* ── Tech name ───────────────────────────────────────────────── */

  .tech-item__name {
    grid-row: 2;
    grid-column: 1;
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    text-align: center;
  }

  /* ── Mobile ──────────────────────────────────────────────────── */

  @media (max-width: 480px) {
    .tech-band__grid {
      gap: 1.5rem 1.75rem;
    }

    .tech-item__star {
      width: 4.5rem;
      height: 4.5rem;
    }
  }
</style>

<script>
  import { scroll } from 'motion';

  const prefersReducedMotion = window.matchMedia(
    '(prefers-reduced-motion: reduce)',
  ).matches;

  if (!prefersReducedMotion) {
    const section = document.querySelector<HTMLElement>('.tech-band')!;
    const items = [...document.querySelectorAll<HTMLElement>('.tech-item')];
    const n = items.length;

    items.forEach((item) => {
      item.style.opacity = '0';
      item.style.transform = 'translateY(12px)';
    });

    scroll(
      (p: number) => {
        items.forEach((item, i) => {
          // Spread items across the first 60% of the scroll range so all are
          // fully visible by the time the section is completely in the viewport.
          // Each item fades over a 7% window of scroll progress.
          const sliceStart = (i / n) * 0.6;
          const sliceEnd = 0.07;
          const t = Math.max(0, Math.min(1, (p - sliceStart) / sliceEnd));
          item.style.opacity = String(t);
          item.style.transform = `translateY(${(t - 1) * -50}px)`;
        });
      },
      {
        target: section,
        offset: ['start end', 'end start'],
      },
    );
  }
</script>
