---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Project } from '../data/projects.ts';

interface Props {
  project: Project;
  period: string;
  description: string;
  linkLive: string;
  linkRepo: string;
}

const { project, period, description, linkLive, linkRepo } = Astro.props;

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/*.webp',
  { eager: true },
);
const thumbnail = images[`../assets/images/${project.id}.webp`];
---

<article class="project-card">
  <div class={`project-card__thumb project-card__thumb--${project.thumbColor}`}>
    {
      thumbnail && (
        <Image
          src={thumbnail.default}
          alt=""
          class="project-card__thumb-img"
          aria-hidden="true"
        />
      )
    }
    <div class="project-card__thumb-text">
      <span class="project-card__thumb-title">{project.title}</span>
      <span class="project-card__thumb-period">{period}</span>
    </div>
  </div>

  <div class="project-card__body">
    <h3 class="project-card__title">{project.title}</h3>
    <p class="project-card__desc">{description}</p>

    <ul class="project-card__tags palette-cycle" role="list">
      {project.tags.map((tag) => <li class="pill">{tag}</li>)}
    </ul>

    <menu class="project-card__links">
      {
        project.liveUrl && (
          <li>
            <a
              href={project.liveUrl}
              class="pill project-card__link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${linkLive} — ${project.title}`}
            >
              {linkLive}
              <span class="ml-1" aria-hidden="true">
                ↗
              </span>
            </a>
          </li>
        )
      }
      <li>
        <a
          href={project.repoUrl}
          class="pill project-card__link project-card__link--repo"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${linkRepo} — ${project.title}`}
        >
          {linkRepo}
        </a>
      </li>
    </menu>
  </div>
</article>

<style>
  /* ── Card shell ─────────────────────────────────────────── */

  .project-card {
    background-color: var(--color-white);
    border: 0.5px solid color-mix(in srgb, var(--color-lavender) 40%, white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    flex: 1 0 450px;
    max-width: min(550px, 100%);
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px
      color-mix(in srgb, var(--color-lavender) 20%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__thumb-img,
    .project-card__thumb::after,
    .project-card__thumb-text {
      transition: none;
    }
  }

  /* ── Thumbnail ───────────────────────────────────────────── */

  .project-card__thumb {
    position: relative;
    overflow: hidden;
    color: var(--color-text-primary);
  }

  .project-card__thumb-img {
    display: block;
    width: 100%;
    height: auto;
    filter: blur(6px);
    transform: scale(1.08);
    transition:
      filter 0.45s ease,
      transform 0.45s ease;
  }

  .project-card:hover .project-card__thumb-img {
    filter: blur(0);
    transform: scale(1);
  }

  .project-card__thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.45s ease;
  }

  .project-card:hover .project-card__thumb::after {
    opacity: 0;
  }

  .project-card__thumb-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem;
    text-align: center;
    transition: opacity 0.45s ease;
  }

  .project-card:hover .project-card__thumb-text {
    opacity: 0;
  }

  .project-card__thumb--wishin::after {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-blush) 82%, transparent),
      color-mix(
        in srgb,
        color-mix(in srgb, var(--color-lavender) 30%, white) 82%,
        transparent
      )
    );
  }

  .project-card__thumb--hctp {
    --hctp-dark: #0c0918;
  }

  .project-card__thumb--hctp::after {
    background-color: color-mix(in srgb, var(--hctp-dark) 50%, transparent);
  }

  .project-card__thumb--hctp .project-card__thumb-text {
    color: var(--color-blush);
  }

  .project-card__thumb--crafty::after {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-ice) 82%, transparent),
      color-mix(
        in srgb,
        color-mix(in srgb, var(--color-lavender) 30%, white) 82%,
        transparent
      )
    );
  }

  .project-card__thumb-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 1.15;
  }

  .project-card__thumb-period {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  /* ── Body ────────────────────────────────────────────────── */

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card__title {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .project-card__desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* ── Tags ────────────────────────────────────────────────── */

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .project-card :global(.pill) {
    font-size: 0.75rem;
  }

  /* ── Links ───────────────────────────────────────────────── */

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-card__link {
    --color: var(--color-sakura);
    background-color: var(--color-white);
    text-decoration: none;
  }

  .project-card__link:hover {
    box-shadow: 0 0 5px 2px var(--color);
  }

  .project-card__link--repo {
    --color: var(--color-ice);
  }
</style>
