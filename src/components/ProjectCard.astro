---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import type { Project } from '../data/projects.ts';

interface Props {
  project: Project;
  period: string;
  description: string;
  linkLive: string;
  linkRepo: string;
  linkVideo: string;
}

const { project, period, description, linkLive, linkRepo, linkVideo } =
  Astro.props;

let embedUrl: string | undefined;
let posterUrl: string | undefined;
if (project.videoUrl) {
  try {
    const raw = project.videoUrl.startsWith('http')
      ? project.videoUrl
      : `https://${project.videoUrl}`;
    const videoId = new URL(raw).searchParams.get('v');
    if (videoId) {
      embedUrl = `https://www.youtube.com/embed/${videoId}`;
      posterUrl = `https://img.youtube.com/vi/${videoId}/hqdefault.jpg`;
    }
  } catch {}
}

const images = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/images/*.webp',
  { eager: true },
);
const thumbnail = images[`../assets/images/${project.id}.webp`];
---

<article class="project-card">
  <div class={`project-card__thumb project-card__thumb--${project.thumbColor}`}>
    {
      thumbnail && (
        <Image
          src={thumbnail.default}
          alt=""
          class="project-card__thumb-img"
          aria-hidden="true"
        />
      )
    }
    <div class="project-card__thumb-text">
      <span class="project-card__thumb-title">{project.title}</span>
      <span class="project-card__thumb-period">{period}</span>
    </div>
  </div>

  <div class="project-card__body">
    <h3 class="project-card__title">{project.title}</h3>
    <p class="project-card__desc">{description}</p>

    <ul class="project-card__tags palette-cycle" role="list">
      {project.tags.map((tag) => <li class="pill">{tag}</li>)}
    </ul>

    <menu class="project-card__links">
      {
        project.liveUrl ? (
          <li>
            <a
              href={project.liveUrl}
              class="pill project-card__link"
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${linkLive} — ${project.title}`}
            >
              {linkLive}
              <span class="ml-1" aria-hidden="true">
                ↗
              </span>
            </a>
          </li>
        ) : (
          embedUrl && (
            <li>
              <button
                type="button"
                class="pill project-card__link project-card__video-btn"
                data-dialog-id={`video-modal-${project.id}`}
                aria-label={`${linkVideo} — ${project.title}`}
              >
                {linkVideo}
                <span class="ml-1" aria-hidden="true">
                  ▶
                </span>
              </button>
            </li>
          )
        )
      }
      <li>
        <a
          href={project.repoUrl}
          class="pill project-card__link project-card__link--repo"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${linkRepo} — ${project.title}`}
        >
          {linkRepo}
        </a>
      </li>
    </menu>
  </div>
</article>

{
  embedUrl && (
    <dialog
      id={`video-modal-${project.id}`}
      class="video-modal"
      aria-label={project.title}
    >
      <div class="video-modal__inner">
        <button
          type="button"
          class="video-modal__close"
          data-close-modal
          aria-label="Close"
        >
          ✕
        </button>
        <iframe
          data-src={embedUrl}
          src=""
          title={project.title}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          class="video-modal__iframe"
          loading="lazy"
        />
        <img
          src={posterUrl}
          alt=""
          aria-hidden="true"
          class="video-modal__poster"
        />
      </div>
    </dialog>
  )
}

<script>
  document
    .querySelectorAll<HTMLButtonElement>('.project-card__video-btn')
    .forEach((btn) => {
      const dialogId = btn.dataset.dialogId!;
      const dialog = document.getElementById(
        dialogId,
      ) as HTMLDialogElement | null;
      if (!dialog) return;

      const iframe = dialog.querySelector<HTMLIFrameElement>(
        '.video-modal__iframe',
      );

      const poster = dialog.querySelector<HTMLElement>('.video-modal__poster');

      btn.addEventListener('click', () => {
        poster?.classList.remove('is-hidden');
        if (iframe) {
          iframe.addEventListener(
            'load',
            () => poster?.classList.add('is-hidden'),
            { once: true },
          );
          iframe.src = iframe.dataset.src ?? '';
        }
        dialog.showModal();
      });

      dialog.addEventListener('close', () => {
        if (iframe) iframe.src = '';
      });

      dialog.addEventListener('click', (e) => {
        if (e.target === dialog) dialog.close();
      });

      dialog
        .querySelector('[data-close-modal]')
        ?.addEventListener('click', () => dialog.close());
    });
</script>

<style>
  /* ── Card shell ─────────────────────────────────────────── */

  .project-card {
    background-color: var(--color-white);
    border: 0.5px solid color-mix(in srgb, var(--color-lavender) 40%, white);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    flex: 1 0 450px;
    max-width: min(550px, 100%);
  }

  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px
      color-mix(in srgb, var(--color-lavender) 20%, transparent);
  }

  @media (prefers-reduced-motion: reduce) {
    .project-card,
    .project-card__thumb-img,
    .project-card__thumb::after,
    .project-card__thumb-text {
      transition: none;
    }
  }

  /* ── Thumbnail ───────────────────────────────────────────── */

  .project-card__thumb {
    position: relative;
    overflow: hidden;
    color: var(--color-text-primary);
  }

  .project-card__thumb-img {
    display: block;
    width: 100%;
    height: auto;
    filter: blur(6px);
    transform: scale(1.08);
    transition:
      filter 0.45s ease,
      transform 0.45s ease;
  }

  .project-card:hover .project-card__thumb-img {
    filter: blur(0);
    transform: scale(1);
  }

  .project-card__thumb::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    opacity: 1;
    transition: opacity 0.45s ease;
  }

  .project-card:hover .project-card__thumb::after {
    opacity: 0;
  }

  .project-card__thumb-text {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 2rem;
    text-align: center;
    transition: opacity 0.45s ease;
  }

  .project-card:hover .project-card__thumb-text {
    opacity: 0;
  }

  .project-card__thumb--wishin::after {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-blush) 82%, transparent),
      color-mix(
        in srgb,
        color-mix(in srgb, var(--color-lavender) 30%, white) 82%,
        transparent
      )
    );
  }

  .project-card__thumb--hctp {
    --hctp-dark: #0c0918;
  }

  .project-card__thumb--hctp::after {
    background-color: color-mix(in srgb, var(--hctp-dark) 50%, transparent);
  }

  .project-card__thumb--hctp .project-card__thumb-text {
    color: var(--color-blush);
  }

  .project-card__thumb--crafty::after {
    background: linear-gradient(
      135deg,
      color-mix(in srgb, var(--color-ice) 82%, transparent),
      color-mix(
        in srgb,
        color-mix(in srgb, var(--color-lavender) 30%, white) 82%,
        transparent
      )
    );
  }

  .project-card__thumb-title {
    font-family: var(--font-display);
    font-size: 2.25rem;
    line-height: 1.15;
  }

  .project-card__thumb-period {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.75;
  }

  /* ── Body ────────────────────────────────────────────────── */

  .project-card__body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .project-card__title {
    font-size: 1.125rem;
    font-weight: 700;
  }

  .project-card__desc {
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
  }

  /* ── Tags ────────────────────────────────────────────────── */

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
  }

  .project-card :global(.pill) {
    font-size: 0.75rem;
  }

  /* ── Links ───────────────────────────────────────────────── */

  .project-card__links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .project-card__link {
    --color: var(--color-sakura);
    background-color: var(--color-white);
    text-decoration: none;
  }

  .project-card__link:hover {
    box-shadow: 0 0 5px 2px var(--color);
  }

  .project-card__link--repo {
    --color: var(--color-ice);
  }

  .project-card__video-btn {
    font: inherit;
    cursor: pointer;
  }

  /* ── Video modal ─────────────────────────────────────────── */

  .video-modal {
    border: none;
    border-radius: var(--radius-lg);
    padding: 0;
    width: min(860px, 92vw);
    background: transparent;
    margin: auto;
    opacity: 0;
    transform: scale(0.95);
    filter: blur(20px);
    transition:
      opacity 0.25s ease,
      transform 0.25s ease,
      display 0.25s allow-discrete,
      overlay 0.25s allow-discrete,
      filter 0.5s ease;
  }

  .video-modal[open] {
    opacity: 1;
    transform: scale(1);
    filter: blur(0);
  }

  @starting-style {
    .video-modal[open] {
      opacity: 0;
      transform: scale(0.95);
      filter: blur(20px);
    }
  }

  .video-modal::backdrop {
    background: color-mix(in srgb, var(--color-text-primary) 70%, transparent);
    backdrop-filter: blur(4px);
    opacity: 0;
    transition:
      opacity 0.25s ease,
      display 0.25s allow-discrete,
      overlay 0.25s allow-discrete;
  }

  .video-modal[open]::backdrop {
    opacity: 1;
  }

  @starting-style {
    .video-modal[open]::backdrop {
      opacity: 0;
    }
  }

  .video-modal__inner {
    position: relative;
    background-color: black;
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .video-modal__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 10;
    background: color-mix(in srgb, var(--color-text-primary) 60%, transparent);
    color: var(--color-white);
    border: none;
    border-radius: 50%;
    width: 2rem;
    height: 2rem;
    font-size: 0.875rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }

  .video-modal__close:hover {
    background: var(--color-text-primary);
  }

  .video-modal__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.4s ease;
  }

  .video-modal__poster.is-hidden {
    opacity: 0;
    pointer-events: none;
  }

  .video-modal__iframe {
    display: block;
    width: 100%;
    aspect-ratio: 16 / 9;
    border: none;
  }
</style>
