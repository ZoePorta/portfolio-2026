---
import { Image } from 'astro:assets';
import photoBottom from '../assets/images/photo-bottom.webp';
import photoTop from '../assets/images/photo-top.webp';
import { useTranslations, getDict, type Locale } from '../i18n/utils';
import { config } from '../data/config';
import { BackgroundGradientAnimation } from './react/BackgroundGradientAnimation';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const { hero } = getDict(lang);
---

<section id="about" aria-labelledby="hero-tagline">
  <BackgroundGradientAnimation client:load className="hero__content">
    <!-- Left column: photo -->
    <div class="hero__photo-col">
      <div class="hero__photo-stack">
        <svg width="0" height="0" style="position:absolute;">
          <defs>
            <clipPath id="blob-clip" clipPathUnits="objectBoundingBox">
              <path
                id="targetPath"
                transform="scale(0.03779)"
                d="M4.35,7.18 C3.89,7.19 3.44,7.3 3.02,7.53 C1.48,8.39 1.47,10.72 0.98,12.41 C0.5,14.09 0.25,15.84 0.1,17.58 C-0.04,19.32 0.04,21.29 1.11,22.59 C2.18,23.88 4.23,24.54 6.27,24.87 C8.3,25.23 10.29,25.29 13.27,25.72 C16.27,26.15 20.23,26.94 22.59,25.78 C24.94,24.62 25.67,21.49 26.13,18.36 C26.59,15.23 26.78,12.08 24.6,10.77 C22.42,9.45 17.88,9.97 14.92,9.91 C11.97,9.86 10.62,9.2 8.72,8.45 C7.3,7.89 5.75,7.13 4.35,7.18 Z"
              ></path>
            </clipPath>
          </defs>
        </svg>
        <div class="hero__photo-clip">
          <Image
            src={photoBottom}
            alt="Zoe Porta, frontend developer"
            class="hero__photo hero__photo--bottom"
            widths={[400, 800]}
            sizes="(max-width: 640px) 80vw, 400px"
            loading="eager"
            fetchpriority="high"
          />
        </div>
        <Image
          src={photoTop}
          alt=""
          aria-hidden="true"
          class="hero__photo hero__photo--top"
          widths={[400, 800]}
          sizes="(max-width: 640px) 80vw, 400px"
          loading="eager"
        />
      </div>
    </div>

    <!-- Right column: text -->
    <div class="hero__text-col">
      <p class="hero__role section-label text-white text-left">
        {t('hero.role')}
      </p>
      <h1 id="hero-tagline" class="hero__tagline">
        {t('hero.tagline')}
        <span class="text-accent">Zoe</span>
      </h1>

      <p class="hero__subtitle">
        {t('hero.subtitle')}
      </p>

      <ul
        class="hero__skills palette-cycle"
        aria-label="Skills and strengths"
        role="list"
      >
        {hero.skills.map((skill) => <li class="pill">{skill}</li>)}
      </ul>

      <footer class="hero__bottom">
        <div class="hero__ctas">
          <a class="btn btn--primary" href="#projects"
            >{t('hero.cta_projects')}</a
          >
          <a
            class="btn btn--secondary"
            href={config.cvUrl.value}
            target="_blank"
            rel="noopener noreferrer"
          >
            {t('hero.cta_cv')}
          </a>
        </div>

        <ul class="hero__social" role="list" aria-label="Social links">
          <li>
            <a
              href={config.linkedin.value}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="LinkedIn"
            >
              <svg
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M20.447 20.452H17.21v-5.569c0-1.328-.027-3.037-1.852-3.037
                     -1.853 0-2.136 1.445-2.136 2.939v5.667H9.989V9h3.12v1.561h.042
                     c.435-.823 1.496-1.691 3.078-1.691 3.292 0 3.9 2.167 3.9 4.984v6.598z
                     M5.337 7.433a1.81 1.81 0 1 1 0-3.62 1.81 1.81 0 0 1 0 3.62z
                     M6.956 20.452H3.717V9h3.239v11.452z"
                ></path>
              </svg>
            </a>
          </li>
          <li>
            <a
              href={config.github.value}
              target="_blank"
              rel="noopener noreferrer"
              aria-label="GitHub"
            >
              <svg
                viewBox="0 0 24 24"
                xmlns="http://www.w3.org/2000/svg"
                aria-hidden="true"
                focusable="false"
              >
                <path
                  d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385
                     .6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04
                     -3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755
                     -1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236
                     1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605
                     -2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22
                     -.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23
                     .96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405
                     2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176
                     .765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92
                     .42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286
                     0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297
                     c0-6.627-5.373-12-12-12"
                ></path>
              </svg>
            </a>
          </li>
        </ul>
      </footer>
    </div>
  </BackgroundGradientAnimation>
</section>

<style>
  /* ── Layout ──────────────────────────────────────────────────── */

  /*
   * hero__content (inside BackgroundGradientAnimation) handles the wave-bottom
   * clearance internally so the gradient covers the full wave area.
   */
  #about {
    padding-bottom: 0;
  }

  /*
   * :global() is required here because className="hero__content" is passed as a prop
   * to BackgroundGradientAnimation and lands on a React-rendered div, which Astro's
   * scope hash never reaches.
   */
  :global(.hero__content) {
    position: relative;
    z-index: 1; /* above gradient blobs inside BackgroundGradientAnimation */
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 2rem 4rem 6rem;
    min-height: 80vh;

    padding-bottom: calc(var(--wave-height) + var(--section-padding));
  }

  /* ── Photo column ────────────────────────────────────────────── */

  .hero__photo-col {
    position: relative;
    max-width: 480px;
  }

  .hero__photo-stack {
    position: relative;
  }

  .hero__photo {
    width: 100%;
    height: auto;
    display: block;
  }

  @property --blob-angle {
    syntax: '<angle>';
    inherits: false;
    initial-value: 56deg;
  }

  .hero__photo-clip {
    clip-path: url(#blob-clip);
  }

  .hero__photo--bottom {
    background: linear-gradient(
      var(--blob-angle),
      var(--color-sakura) 5%,
      var(--color-lavender) 30%,
      var(--color-periwinkle) 50%,
      var(--color-ice) 84%
    );
    transform-origin: bottom center;
    transition:
      --blob-angle 0.6s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__photo--top {
    transform-origin: bottom center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__photo-stack:hover .hero__photo--bottom,
  .hero__photo-stack:hover .hero__photo--top {
    transform: scale(1.04);
  }

  .hero__photo-stack:hover .hero__photo--bottom {
    --blob-angle: 210deg;
  }

  .hero__photo-stack:hover #targetPath {
    d: path(
      'M7.66,7.44 C6.69,7.14 5.62,6.87 4.60,6.84 C3.58,6.80 2.62,6.99 1.88,7.61 C0.53,8.74 0.68,11.02 0.8,12.78 C0.95,14.86 2.77,16.92 2.95,18.66 C3.14,20.4 1.12,23.69 2.42,24.76 C3.71,25.83 5.85,26.09 7.91,26.05 C9.98,26.01 11.94,25.7 14.95,25.56 C17.97,25.42 22.01,25.45 24.12,23.86 C26.2,22.28 23.59,20.72 23.45,17.56 C23.31,14.4 22.91,11.27 20.52,10.39 C18.13,9.51 16.51,9.22 13.6,9.72 C10.69,10.22 10.32,8.27 7.66,7.44 Z'
    );
  }

  #targetPath {
    transition: d 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .hero__photo--top {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  /* ── Text column ─────────────────────────────────────────────── */

  .hero__role {
    text-shadow: 0 0 6px var(--color-periwinkle);
  }
  .hero__tagline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    line-height: 1.1;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
    margin-top: 1.25rem;
  }

  .hero__subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: 2rem;
  }

  /* ── Skill bubbles ───────────────────────────────────────────── */

  .hero__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-bottom: 2.5rem;
  }

  /* ── CTAs + Social ──────────────────────────────────────────── */

  .hero__bottom {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── Social links ────────────────────────────────────────────── */

  .hero__social {
    display: flex;
    gap: 0.875rem;
    list-style: none;
  }

  .hero__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--color-white);
    border: 1px solid var(--color-lavender);
    color: var(--color-text-secondary);
    transition:
      color 0.2s ease,
      border-color 0.2s ease;
  }

  .hero__social a:hover,
  .hero__social a:focus-visible {
    color: var(--color-text-primary);
    border-color: var(--color-sakura);
  }

  .hero__social svg {
    width: 1.125rem;
    height: 1.125rem;
    fill: currentColor;
  }

  /* ── Mobile ──────────────────────────────────────────────────── */

  @media (max-width: 768px) {
    :global(.hero__content) {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem 4rem;
      text-align: center;
    }

    .hero__photo-col {
      max-width: 320px;
      margin-inline: auto;
    }

    .hero__subtitle {
      max-width: none;
    }

    .hero__skills {
      justify-content: center;
    }

    .hero__bottom {
      justify-content: center;
    }
    .hero__ctas {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__social a,
    .hero__photo--bottom,
    .hero__photo--top,
    #targetPath {
      transition: none;
    }
  }
</style>
