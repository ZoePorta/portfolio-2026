---
import { Image } from 'astro:assets';
import fotoZoe from '../assets/images/fotoZoe.png';
import type { Locale } from '../i18n/utils';
import { BackgroundGradientAnimation } from './react/BackgroundGradientAnimation';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="hero" aria-labelledby="hero-tagline">
  <BackgroundGradientAnimation client:load className="hero__content">

  <!-- Left column: photo -->
  <div class="hero__photo-col">

    <Image
      src={fotoZoe}
      alt="Zoe Porta, frontend developer"
      class="hero__photo"
      widths={[400, 800]}
      sizes="(max-width: 640px) 80vw, 400px"
      loading="eager"
      fetchpriority="high"
    />

  </div>

  <!-- Right column: text -->
  <div class="hero__text-col">

    <h1 id="hero-tagline" class="hero__tagline">The craft is in the details</h1>

    {/* TODO: replace with real subtitle copy */}
    <p class="hero__subtitle">Frontend developer. I build things that are as solid underneath as they are beautiful on the surface.</p>

    <ul class="hero__skills" aria-label="Skills and strengths" role="list">
      <li>Lateral thinking</li>
      <li>Makes complexity feel simple</li>
      <li>Informal tech lead</li>
      <li>Owns the design</li>
      <li>Documents for the next dev</li>
      <li>AI image generation</li>
      <li>SVG vectorization</li>
    </ul>

    <div class="hero__ctas">
      <a class="hero__cta hero__cta--primary" href="#projects">Ver proyectos</a>
      <a class="hero__cta hero__cta--secondary" href="#" target="_blank" rel="noopener noreferrer">
        Consulta mi CV
      </a>
    </div>

    <ul class="hero__social" role="list" aria-label="Social links">
      <li>
        <a href="https://linkedin.com/in/zoeporta" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M20.447 20.452H17.21v-5.569c0-1.328-.027-3.037-1.852-3.037
                     -1.853 0-2.136 1.445-2.136 2.939v5.667H9.989V9h3.12v1.561h.042
                     c.435-.823 1.496-1.691 3.078-1.691 3.292 0 3.9 2.167 3.9 4.984v6.598z
                     M5.337 7.433a1.81 1.81 0 1 1 0-3.62 1.81 1.81 0 0 1 0 3.62z
                     M6.956 20.452H3.717V9h3.239v11.452z"/>
          </svg>
        </a>
      </li>
      <li>
        <a href="https://github.com/ZoePorta" target="_blank" rel="noopener noreferrer" aria-label="GitHub">
          <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385
                     .6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04
                     -3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755
                     -1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236
                     1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605
                     -2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22
                     -.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23
                     .96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405
                     2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176
                     .765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92
                     .42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286
                     0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297
                     c0-6.627-5.373-12-12-12"/>
          </svg>
        </a>
      </li>
    </ul>

  </div>

  </BackgroundGradientAnimation>
</section>

<style>
  /* ── Layout ──────────────────────────────────────────────────── */

  /*
   * :global() is required here because className="hero__content" is passed as a prop
   * to BackgroundGradientAnimation and lands on a React-rendered div, which Astro's
   * scope hash never reaches.
   */
  :global(.hero__content) {
    position: relative;
    z-index: 1; /* above gradient blobs inside BackgroundGradientAnimation */
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
    padding: 2rem 4rem 6rem;
  }

  /* ── Photo column ────────────────────────────────────────────── */

  .hero__photo-col {
    position: relative;
    max-width: 480px;
  }

  .hero__photo {
    width: 100%;
    height: auto;
  }

  /* ── Text column ─────────────────────────────────────────────── */

  .hero__tagline {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 4.5vw, 4.5rem);
    line-height: 1.1;
    color: var(--color-text-primary);
    margin-bottom: 1.25rem;
  }

  .hero__subtitle {
    font-size: 1.0625rem;
    color: var(--color-text-secondary);
    line-height: 1.7;
    max-width: 44ch;
    margin-bottom: 2rem;
  }

  /* ── Skill bubbles ───────────────────────────────────────────── */

  .hero__skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin-bottom: 2.5rem;
  }

  .hero__skills li {
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.375rem 0.9rem;
    border-radius: 999px;
    background-color: var(--color-white);
    color: var(--color-text-secondary);
    border: 1px solid var(--color-lavender);
  }

  /* ── CTAs ────────────────────────────────────────────────────── */

  .hero__ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 2rem;
  }

  .hero__cta {
    font-size: 0.9375rem;
    font-weight: 600;
    padding: 0.75rem 1.875rem;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .hero__cta--primary {
    background-color: var(--color-sakura);
    color: var(--color-text-primary);
  }

  .hero__cta--secondary {
    background-color: transparent;
    color: var(--color-text-primary);
    border: 1.5px solid var(--color-lavender);
  }

  .hero__cta:hover,
  .hero__cta:focus-visible {
    opacity: 0.8;
  }

  /* ── Social links ────────────────────────────────────────────── */

  .hero__social {
    display: flex;
    gap: 0.875rem;
    list-style: none;
  }

  .hero__social a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background-color: var(--color-white);
    border: 1px solid var(--color-lavender);
    color: var(--color-text-secondary);
    transition: color 0.2s ease, border-color 0.2s ease;
  }

  .hero__social a:hover,
  .hero__social a:focus-visible {
    color: var(--color-text-primary);
    border-color: var(--color-sakura);
  }

  .hero__social svg {
    width: 1.125rem;
    height: 1.125rem;
    fill: currentColor;
  }

  /* ── Mobile ──────────────────────────────────────────────────── */

  @media (max-width: 768px) {
    :global(.hero__content) {
      grid-template-columns: 1fr;
      padding: 2rem 1.5rem 4rem;
      text-align: center;
    }

    .hero__photo-col {
      max-width: 320px;
      margin-inline: auto;
    }

    .hero__subtitle {
      max-width: none;
    }

    .hero__skills {
      justify-content: center;
    }

    .hero__ctas {
      justify-content: center;
    }

    .hero__social {
      justify-content: center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__cta,
    .hero__social a {
      transition: none;
    }
  }
</style>
